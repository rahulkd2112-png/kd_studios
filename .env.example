# Neon pooled connection (runtime/serverless)
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-NEON-HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Neon direct connection (Prisma migrations)
DIRECT_URL="postgresql://USER:PASSWORD@YOUR-NEON-HOST.REGION.aws.neon.tech/neondb?sslmode=require"
NODE_ENV="development"
PORT=4000
JWT_SECRET="change-this-to-a-long-random-secret"
FRONTEND_ORIGIN="http://localhost:3000"
ADMIN_OTP_TTL_MINUTES=10
ADMIN_OTP_MAX_ATTEMPTS=5
PASSWORD_RESET_OTP_TTL_MINUTES=15
PASSWORD_RESET_OTP_MAX_ATTEMPTS=5
REGISTRATION_OTP_MAX_ATTEMPTS=5
EMAIL_USER="your-gmail-address@gmail.com"
EMAIL_PASS="your-16-character-google-app-password"
EMAIL_FROM="KD Studios <your-gmail-address@gmail.com>"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
SOCKET_PATH="/ws"
TRUST_PROXY=false
ADMIN_NAME="KD Studios Admin"
ADMIN_EMAIL="rahulkd2112@gmail.com"
ADMIN_PHONE="8340510698"
